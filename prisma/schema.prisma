generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  picture  String?

  role              UserRole   @default(REGULAR)
  method            AuthMethod
  isVerified        Boolean    @default(false) @map("is_verified")
  isTwoFactorEnable Boolean    @default(false) @map("is_two_factor_enable")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts Account[]
  shops    Shop[]
  reviews  Review[]
  orders   Order[]

  basket    Basket?
  favorites Favorites?

  @@map("users")
}

model Shop {
  id String @id @default(uuid())

  title       String  @unique
  description String
  picture     String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  products   Product[]
  categories Category[]
  colors     Color[]
  reviews    Review[]
  orderItems OrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("shops")
}

model Product {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Int
  images      String[]

  groupedOptions GroupOptions[]
  reviews        Review[]
  orderItems     OrderItem[]
  basketItems    BasketItem[]
  favoritesItems FavoritesItem[]

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId String @map("shop_id")

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String   @map("category_id")

  color   Color?  @relation(fields: [colorId], references: [id], onDelete: SetNull)
  colorId String? @map("color_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([shopId])
  @@index([categoryId])
  @@map("products")
}

model GroupOptions {
  id String @id @default(uuid())

  groupName String

  options ProductsOptions[]

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@map("group_options")
}

model ProductsOptions {
  id String @id @default(uuid())

  name  String
  value String

  groupOptions   GroupOptions @relation(fields: [groupOptionsId], references: [id], onDelete: Cascade)
  groupOptionsId String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_options")
}

model Basket {
  id String @id @default(uuid())

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @unique @map("user_id")

  basketItems BasketItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("baskets")
}

model BasketItem {
  id       String @id @default(uuid())
  quantity Int    @default(1)

  basket   Basket @relation(fields: [basketId], references: [id], onDelete: Cascade)
  basketId String @map("basket_id")

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([basketId, productId])
  @@index([basketId])
  @@index([productId])
  @@map("basket_items")
}

model Favorites {
  id          String @id @default(uuid())
  totalAmount Int    @default(0)

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @unique @map("user_id")

  favoritesItems FavoritesItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("favorites")
}

model FavoritesItem {
  id String @id @default(uuid())

  favorites   Favorites @relation(fields: [favoritesId], references: [id], onDelete: Cascade)
  favoritesId String    @map("favorites_id")

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([favoritesId])
  @@index([productId])
  @@map("favorites_items")
}

model Category {
  id String @id @default(uuid())

  title       String
  description String

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId String @map("shop_id")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([shopId])
  @@map("categories")
}

model Color {
  id String @id @default(uuid())

  title String
  value String

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId String @map("shop_id")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([shopId])
  @@map("colors")
}

model Review {
  id String @id @default(uuid())

  text   String
  rating Int

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId String @map("shop_id")

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([shopId])
  @@index([productId])
  @@map("reviews")
}

model Order {
  id String @id @default(uuid())

  status EnumOrderStatus @default(PENDING)
  total  Int

  items OrderItem[]

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id String @id @default(uuid())

  quantity Int
  price    Int

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String @map("order_id")

  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId String?  @map("product_id")

  shop   Shop?   @relation(fields: [shopId], references: [id], onDelete: SetNull)
  shopId String? @map("shop_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@map("order_items")
}

model Account {
  id String @id @default(uuid())

  type     String
  provider String

  accessToken  String? @map("access_token")
  refreshToken String? @map("refresh_token")
  expiresAt    Int?    @map("expires_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("accounts")
}

model Token {
  id String @id @default(uuid())

  email     String
  token     String    @unique
  type      TokenType
  expiresIn DateTime  @map("expires_in")

  @@map("tokens")
}

enum UserRole {
  REGULAR
  ADMIN

  @@map("user_roles")
}

enum AuthMethod {
  CREDENTIALS
  GOOGLE
  YANDEX

  @@map("auth_methods")
}

enum TokenType {
  VERIFICATION
  TWO_FACTOR
  PASSWORD_RESET

  @@map("token_types")
}

enum EnumOrderStatus {
  PENDING
  PAYED

  @@map("enum_order_statuses")
}
